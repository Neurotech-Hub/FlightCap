/dts-v1/;
#include <nordic/nrf52833_qdaa.dtsi>
#include <zephyr/dt-bindings/adc/nrf-saadc.h>
#include <zephyr/dt-bindings/i2c/i2c.h>
#include "FlightCap_nRF52833-pinctrl.dtsi"

/ {
	model = "FlightCap_nRF52833";
	compatible = "NeurotechHub,FlightCap_nRF52833";

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,code-partition = &slot0_partition;
	};

	leds {
		compatible = "gpio-leds";
		led1: led_1 {
			gpios = <&gpio0 2 GPIO_ACTIVE_HIGH>;
			label = "LED1";
		};
		led0: led_0 {
			gpios = <&gpio0 3 GPIO_ACTIVE_HIGH>;
			label = "LED0";
		};
	};

	/* TOF_EN drives TPS63900 EN (active high) to switch VL53L0X rail. */
	tof_ctrl {
		compatible = "gpio-leds";
		tof_en: tof_en {
			gpios = <&gpio0 9 GPIO_ACTIVE_HIGH>;
			label = "TOF TPS63900 enable";
		};
	};

	gpio_keys {
		compatible = "gpio-keys";
		magnet_sensor: magnet_sensor {
			gpios = <&gpio1 9 GPIO_ACTIVE_LOW>;
			label = "Magnet detect interrupt";
		};
		accel_int2: accel_int2 {
			gpios = <&gpio0 15 GPIO_ACTIVE_LOW>;
			label = "Accelerometer interrupt 2";
		};
		accel_int1: accel_int1 {
			gpios = <&gpio0 17 GPIO_ACTIVE_LOW>;
			label = "Accelerometer interrupt 1";
		};
	};

	/* SAADC channel 0: internal VDD (coin cell on VDD, no external pin). */
	zephyr,user {
		io-channels = <&adc 0>;
	};

	aliases {
		led0 = &led0;
		led1 = &led1;
		magnet-sensor = &magnet_sensor;
		accel-int = &accel_int1;
		accel-int2 = &accel_int2;
		i2c-bus = &i2c0;
		tof-sensor = &vl53l0x;
		tof-enable = &tof_en;
		spi-flash = &mx25r8035;
	};
};

/*
 * nRF52 (incl. nRF52833) has no lfxo/hfxo devicetree nodes in NCS 3.0 — LF/HF
 * crystal selection is via Kconfig in FlightCap_nRF52833_defconfig.
 */

&gpio0 {
	status = "okay";
};

&gpio1 {
	status = "okay";
};

&gpiote {
	status = "okay";
};

&rtc0 {
	status = "okay";
};

&wdt0 {
	status = "okay";
};

/*
 * Shared I2C bus (TWIM0): SCL P0.04, SDA P0.05 @ 100 kHz.
 *   LIS2DH12 @ 0x19 (SA0 high)
 *   VL53L0X @ 0x29 (Zephyr sensor driver in flightcap-prod)
 */
&i2c0 {
	compatible = "nordic,nrf-twim";
	status = "okay";
	pinctrl-0 = <&i2c0_default>;
	pinctrl-1 = <&i2c0_sleep>;
	pinctrl-names = "default", "sleep";
	clock-frequency = <I2C_BITRATE_STANDARD>;

	lis2dh12: lis2dh12@19 {
		compatible = "st,lis2dh12";
		reg = <0x19>;
	};

	vl53l0x: vl53l0x@29 {
		compatible = "st,vl53l0x";
		reg = <0x29>;
		label = "VL53L0X";
	};
};

/*
 * SPI NOR flash (MX25R8035F 8 Mb) on SPIM1. Instance 0 is shared between
 * TWIM0 and SPIM0, so I2C uses &i2c0 and SPI must use &spi1 (same pattern
 * as nrf52833dk). Physical pins unchanged: CS P0.28, SCK/MISO/MOSI P0.29-31.
 */
&spi1 {
	compatible = "nordic,nrf-spim";
	status = "okay";
	pinctrl-0 = <&spi1_default>;
	pinctrl-1 = <&spi1_sleep>;
	pinctrl-names = "default", "sleep";
	cs-gpios = <&gpio0 28 GPIO_ACTIVE_LOW>;

	mx25r8035: mx25r8035@0 {
		compatible = "jedec,spi-nor";
		reg = <0>;
		spi-max-frequency = <8000000>;
		jedec-id = [c2 28 14];
		size = <DT_SIZE_M(1)>;
		label = "MX25R8035";
	};
};

&adc {
	status = "okay";
	#address-cells = <1>;
	#size-cells = <0>;

	channel@0 {
		reg = <0>;
		zephyr,gain = "ADC_GAIN_1_6";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,input-positive = <NRF_SAADC_VDD>;
		zephyr,resolution = <12>;
	};
};

&flash0 {
	partitions {
		compatible = "fixed-partitions";
		#address-cells = <1>;
		#size-cells = <1>;

		boot_partition: partition@0 {
			label = "mcuboot";
			reg = <0x00000000 DT_SIZE_K(48)>;
		};

		slot0_partition: partition@c000 {
			label = "image-0";
			reg = <0x0000c000 DT_SIZE_K(232)>;
		};

		slot1_partition: partition@46000 {
			label = "image-1";
			reg = <0x00046000 DT_SIZE_K(232)>;
		};
	};
};
